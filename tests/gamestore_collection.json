    {
      "name": "3. Créer un jeu",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TODO — Vérifier status 201 et récupérer l'id pour le chaînage :",
              "",
              "pm.test('Créé', () => pm.response.to.have.status(201));",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test(\"id présent\", () => {",
              "    pm.expect(json).to.have.property(\"id\");",
              "});",
              "",
              "const id = Number(json.id);",
              "",
              "pm.test(\"id valide\", () => {",
              "    pm.expect(id).to.be.a(\"number\");",
              "    pm.expect(id).to.be.greaterThan(0);",
              "});",
              "",
              "pm.collectionVariables.set(\"created_game_id\", id);",
              "",
              "console.log(\"ID STOCKÉ =\", id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"NexusGame Test {{$timestamp}}\",\n  \"genre\": \"RPG\",\n  \"price\": 49.99,\n  \"rating\": 4.5,\n  \"stock\": 100\n}"
        },
        "url": {
          "raw": "{{base_url}}/games",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "games"
          ]
        }
      },
      "response": []
    },
    {
      "name": "4. Récupérer le jeu créé",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseJson = pm.response.json();",
              "const createdGameId = Number(pm.collectionVariables.get(\"created_game_id\"));",
              "",
              "pm.test(\"created_game_id existe\", () => {",
              "    pm.expect(createdGameId).to.exist;",
              "    pm.expect(createdGameId).to.be.a(\"number\");",
              "    pm.expect(createdGameId).to.be.greaterThan(0);",
              "});",
              "",
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"ID correspond\", function () {",
              "    pm.expect(responseJson.id).to.eql(createdGameId);",
              "});",
              "",
              "pm.test(\"Titre OK\", function () {",
              "    pm.expect(responseJson.title).to.be.a(\"string\").and.not.empty;",
              "});",
              "",
              "pm.test(\"Genre OK\", function () {",
              "    pm.expect(responseJson.genre).to.be.a(\"string\").and.not.empty;",
              "});",
              "",
              "pm.test(\"Prix OK\", function () {",
              "    pm.expect(responseJson.price).to.be.a(\"number\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
