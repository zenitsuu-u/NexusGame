    {
      "name": "2. Lister les jeux",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TODO — Vérifier :",
              "// - status 200",
              "// - réponse est un tableau",
              "// - tableau non vide",
              "// - chaque jeu contient les champs attendus",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "    });",
              "",
              "pm.test(\"La réponse est un tableau\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"Le tableau n'est pas vide\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an(\"array\")",
              "});",
              "",
              "pm.test(\"Chaque jeu contient les champs attendus\", function () {",
              "    const json = pm.response.json();",
              "    json.forEach(function (game) {",
              "        pm.expect(game).to.have.property(\"id\");",
              "        pm.expect(game).to.have.property(\"title\");",
              "        pm.expect(game).to.have.property(\"price\");",
              "        pm.expect(game).to.have.property(\"genre\");",
              "    });",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/games",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "games"
          ]
        }
      },
      "response": []
